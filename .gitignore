# ================================================
# OS Generated Files
# ================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ================================================
# Backend - Java/Maven/Spring Boot
# ================================================
# Maven构建输出
backend/target/
backend/*/target/

# IDE配置
backend/.idea/
backend/.vscode/
backend/*.iml
backend/*.ipr
backend/*.iws

# 日志文件
backend/log/
backend/logs/
*.log
*.log.*

# 编译输出
*.class
*.war
*.ear

# ================================================
# Frontend - Node/Vue
# ================================================
# 依赖
frontend/node_modules/
frontend/*/node_modules/

# 构建输出
frontend/dist/
frontend/dist-ssr/

# 日志
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# 本地环境配置
frontend/.env.local
frontend/.env.*.local
frontend/.env.development
frontend/.env.production

# 缓存
frontend/.eslintcache
frontend/.stylelintcache
frontend/.cache/

# ================================================
# Database - 上传文件
# ================================================
